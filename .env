# PetMat Application Environment Variables
# Copy this file to .env.local for local development
# Do not commit .env.local to version control

# =============================================================================
# API CONFIGURATION
# =============================================================================

# Main API Base URL (يجب أن يكون متطابقاً مع PORT في server/.env)
VITE_API_BASE=http://localhost:5000/api

# AI Matching Service URL
VITE_AI_SERVICE_URL=http://localhost:8001

# Chat Service URL  
VITE_CHAT_SERVICE_URL=http://localhost:3001

# File Upload Service URL
VITE_FILE_UPLOAD_URL=http://localhost:5000/api/upload

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# HaveIBeenPwned API for password breach checking
VITE_PWNED_PASSWORDS_API_URL=https://api.pwnedpasswords.com

# Image CDN or Storage Service
VITE_IMAGE_CDN_URL=https://images.unsplash.com

# Payment Service URLs
VITE_STRIPE_API_URL=https://api.stripe.com
VITE_PAYMOB_API_URL=https://accept.paymob.com

# =============================================================================
# SOCIAL LOGIN CONFIGURATION
# =============================================================================

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Facebook OAuth
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here
VITE_FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Connection (for server-side only)
# Note: These are typically not exposed to frontend
# DATABASE_URL=...
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=pet_breeding_db
DATABASE_USER=postgres
DATABASE_PASSWORD=yehia.hema195200

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Configuration
VITE_JWT_SECRET=your_super_secure_jwt_secret_key_here
VITE_JWT_EXPIRES_IN=7d
VITE_JWT_REFRESH_EXPIRES_IN=30d

# Encryption Keys
VITE_ENCRYPTION_KEY=your_32_character_encryption_key_here
VITE_PASSWORD_SALT=your_password_salt_here

# =============================================================================
# THIRD-PARTY API KEYS
# =============================================================================

# Email Service (SendGrid, Mailgun, etc.)
VITE_EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
VITE_EMAIL_FROM=noreply@petmat.com
VITE_EMAIL_FROM_NAME=PetMat

# SMS Service (Twilio, etc.)
VITE_TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
VITE_TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
VITE_TWILIO_PHONE_NUMBER=+1234567890

# Cloud Storage (AWS S3, Google Cloud, etc.)
VITE_AWS_ACCESS_KEY_ID=your_aws_access_key_here
VITE_AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
VITE_AWS_REGION=us-east-1
VITE_AWS_S3_BUCKET=petmat-uploads

# Analytics Services
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
VITE_SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Environment
VITE_NODE_ENV=development
VITE_APP_NAME=PetMat
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_AI_MATCHING=true
VITE_ENABLE_CHAT=true
VITE_ENABLE_FILE_UPLOAD=true
VITE_ENABLE_SOCIAL_LOGIN=true
VITE_ENABLE_ANALYTICS=false

# Debug Configuration
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Development Server
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=localhost

# Mock Services (for development)
VITE_USE_MOCK_SERVICES=true
VITE_MOCK_API_DELAY=1000

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production URLs (update these for production)
VITE_PRODUCTION_API_URL=https://api.petmat.com
VITE_PRODUCTION_AI_SERVICE_URL=https://ai.petmat.com
VITE_PRODUCTION_CHAT_SERVICE_URL=https://chat.petmat.com

# CDN Configuration
VITE_CDN_URL=https://cdn.petmat.com
VITE_ASSETS_URL=https://assets.petmat.com

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Testing Environment
VITE_TEST_API_URL=http://localhost:3001/api/v1
VITE_TEST_AI_SERVICE_URL=http://localhost:8002
VITE_TEST_CHAT_SERVICE_URL=http://localhost:3002

# Test Database
VITE_TEST_DATABASE_URL=postgresql://test:test@localhost:5432/petmat_test

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Logging Service
VITE_LOG_SERVICE_URL=https://logs.petmat.com
VITE_LOG_LEVEL=info

# Health Check URLs
VITE_HEALTH_CHECK_URL=https://health.petmat.com
VITE_STATUS_PAGE_URL=https://status.petmat.com

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================

# Rate Limiting
# NOTE: ADMIN and SUPER_ADMIN users have UNLIMITED access (bypasses all rate limits)
# See ADMIN_UNLIMITED_ACCESS.md for details
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW=900000

# CORS Configuration
VITE_CORS_ORIGIN=https://petmat.com
VITE_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
VITE_CORS_ALLOWED_HEADERS=Content-Type,Authorization

# =============================================================================
# LOCALIZATION & INTERNATIONALIZATION
# =============================================================================

# Default Language
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,ar

# Currency Configuration
VITE_DEFAULT_CURRENCY=USD
VITE_SUPPORTED_CURRENCIES=USD,EUR,GBP

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================

# Push Notifications
VITE_PUSH_NOTIFICATION_PUBLIC_KEY=your_vapid_public_key_here
VITE_PUSH_NOTIFICATION_PRIVATE_KEY=your_vapid_private_key_here
VITE_PUSH_NOTIFICATION_EMAIL=your_push_notification_email_here

# Email Notifications
VITE_NOTIFICATION_QUEUE_URL=https://queue.petmat.com
VITE_NOTIFICATION_WORKER_URL=https://worker.petmat.com

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis Configuration (if used)
VITE_REDIS_URL=redis://localhost:6379
VITE_REDIS_CACHE_TTL=3600

# Browser Cache
VITE_BROWSER_CACHE_TTL=300000
VITE_SERVICE_WORKER_CACHE_TTL=86400000

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================

# Webhook URLs
VITE_WEBHOOK_SECRET=your_webhook_secret_here
VITE_WEBHOOK_URL=https://webhooks.petmat.com

# =============================================================================
# BACKUP & ARCHIVAL
# =============================================================================

# Backup Configuration
VITE_BACKUP_SERVICE_URL=https://backup.petmat.com
VITE_BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_here

# =============================================================================
# LEGAL & COMPLIANCE
# =============================================================================

# Privacy Policy
VITE_PRIVACY_POLICY_URL=https://petmat.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://petmat.com/terms

# GDPR Configuration
VITE_GDPR_COMPLIANCE=true
VITE_DATA_RETENTION_DAYS=365

# =============================================================================
# PERFORMANCE & OPTIMIZATION
# =============================================================================

# Performance Monitoring
VITE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# Bundle Optimization
VITE_BUNDLE_ANALYZER=false
VITE_SOURCE_MAP=true

# =============================================================================
# EXPERIMENTAL FEATURES
# =============================================================================

# Experimental Features (set to false in production)
VITE_ENABLE_EXPERIMENTAL_FEATURES=false
VITE_ENABLE_BETA_FEATURES=false
VITE_ENABLE_DEBUG_TOOLS=false
