# =============================================================================
# TESTING ENVIRONMENT
# Minimal setup for automated testing
# =============================================================================

PORT=5001
NODE_ENV=test
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://test:test@localhost:5432/petmate_test
JWT_SECRET=test-jwt-secret-key

# Minimal features for testing
ENABLE_AUTH=true
ENABLE_SOCKETS=false
ENABLE_LOGGING=false
ENABLE_COMPRESSION=false
ENABLE_RATE_LIMIT=false
ENABLE_SECURITY=false
ENABLE_CORS=true
ENABLE_MOCK_DATA=true
ENABLE_DATABASE=false
ENABLE_NOTIFICATIONS=false
ENABLE_SCHEDULERS=false
ENABLE_FILE_UPLOAD=false
ENABLE_PAYMENTS=false
ENABLE_EMAIL=false
ENABLE_GPS=false
ENABLE_AI=false
ENABLE_ANALYTICS=false
ENABLE_VET_SERVICES=false
ENABLE_MESSAGING=false

# No rate limiting for tests
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000

# Minimal logging
LOG_LEVEL=error

# =============================================================================
# Why this configuration?
# =============================================================================

# ENABLE_MOCK_DATA=true: Use predictable mock data for tests
# ENABLE_DATABASE=false: Avoid database dependencies in tests
# ENABLE_RATE_LIMIT=false: Prevent rate limiting in test runs
# ENABLE_LOGGING=false: Clean test output
# Most features disabled: Focus on core functionality
# PORT=5001: Avoid conflicts with development server
