// ============================================================================
// Pet Breeding Matchmaking Platform - Enhanced Database Schema
// Version: 2.0 - Enterprise Grade
// Last Updated: 2026-02-09
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER MANAGEMENT MODELS
// ============================================================================

model users {
  id                                                      String              @id @default(uuid())
  email                                                   String              @unique @db.VarChar(255)
  password                                                String
  firstName                                               String              @db.VarChar(100)
  lastName                                                String              @db.VarChar(100)
  phone                                                   String?             @db.VarChar(20)
  avatar                                                  String?             @db.VarChar(500)
  bio                                                     String?
  address                                                 String?             @db.VarChar(500)
  city                                                    String?             @db.VarChar(100)
  country                                                 String?             @db.VarChar(100)
  
  // Authentication & Security
  role                                                    Role                @default(USER)
  isVerified                                              Boolean             @default(false)
  verificationToken                                       String?             @unique @db.VarChar(255)
  verificationExpiresAt                                   DateTime?
  passwordResetToken                                      String?             @unique @db.VarChar(255)
  passwordResetExpiresAt                                  DateTime?
  
  // User Status & Activity
  isActive                                                Boolean             @default(true)
  lastActivityDate                                        DateTime            @default(now())
  lastLoginDate                                           DateTime?
  loginAttempts                                           Int                 @default(0)
  lastLoginAttempt                                        DateTime?
  
  // Reputation & Rating
  rating                                                  Float               @default(0)
  totalMatches                                            Int                 @default(0)
  totalReviews                                            Int                 @default(0)
  
  // Warnings & Bans
  isBanned                                                Boolean             @default(false)
  bannedAt                                                DateTime?
  bannedBy                                                String?
  bannedReason                                            String?
  lastWarningAt                                           DateTime?
  warnings                                                Int                 @default(0)
  
  // User Blocking System
  isBlocked                                               Boolean             @default(false)
  blockReason                                             String?
  
  // Subscription
  subscriptionTier                                        SubscriptionTier    @default(FREE)
  
  // Timestamps
  createdAt                                               DateTime            @default(now())
  updatedAt                                               DateTime            @updatedAt
  deletedAt                                               DateTime?
  
  // Relations
  breeding_requests_initiator                             breeding_requests[] @relation("breeding_requests_initiatorIdTousers")
  breeding_requests_target                                breeding_requests[] @relation("breeding_requests_targetUserIdTousers")
  clinic_bookings                                         clinic_bookings[]
  messages_received                                       messages[]          @relation("messages_recipientIdTousers")
  messages_sent                                           messages[]          @relation("messages_senderIdTousers")
  pets                                                    pets[]
  refresh_tokens                                          refresh_tokens[]
  reports_reported                                        reports[]           @relation("reports_reportedUserIdTousers")
  reports_reported_by                                     reports[]           @relation("reports_reporterUserIdTousers")
  reviews_received                                        reviews[]           @relation("reviews_revieweeIdTousers")
  reviews_given                                           reviews[]           @relation("reviews_reviewerIdTousers")
  subscriptions                                           subscriptions?
  support_tickets                                         support_tickets[]
  blocked_users_blocker                                   blocked_users[]     @relation("blocker")
  blocked_users_blocked                                   blocked_users[]     @relation("blocked")
  activity_logs                                           activity_logs[]
  audit_logs                                              audit_logs[]
  
  // Indexes
  @@unique([email])
  @@index([city])
  @@index([createdAt])
  @@index([email])
  @@index([isBanned])
  @@index([isVerified])
  @@index([role])
  @@index([isActive])
  @@index([lastActivityDate])
  @@index([verificationExpiresAt])
  @@index([passwordResetExpiresAt])
}

// User Blocking System
model blocked_users {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  reason    String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  blocker users @relation("blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked users @relation("blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  
  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@index([createdAt])
}

// User Activity Tracking
model activity_logs {
  id        String   @id @default(uuid())
  userId    String
  action    String   @db.VarChar(100)
  details   Json?
  ipAddress String?  @db.VarChar(50)
  userAgent String?
  createdAt DateTime @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model refresh_tokens {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([expiresAt])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// PET MANAGEMENT MODELS
// ============================================================================

model pets {
  id                                                       String              @id @default(uuid())
  ownerId                                                  String
  name                                                     String              @db.VarChar(100)
  species                                                  String              @db.VarChar(50)
  breed                                                    String              @db.VarChar(100)
  gender                                                   Gender
  dateOfBirth                                              DateTime?
  weight                                                   Float?
  height                                                   Float?
  color                                                    String?             @db.VarChar(100)
  distinctiveFeatures                                      String?
  
  // Health Information
  isVaccinated                                             Boolean             @default(false)
  isNeutered                                               Boolean             @default(false)
  healthConditions                                         String?
  lastHealthCheckDate                                      DateTime?
  nextVaccinationDate                                      DateTime?
  lastBreedingDate                                         DateTime?
  
  // Breeding Information
  breedingStatus                                           BreedingStatus      @default(NOT_AVAILABLE)
  breedingPrice                                            Float?
  nextAvailableDate                                        DateTime?
  totalOffspringCount                                      Int                 @default(0)
  retirementDate                                           DateTime?
  
  // Documentation
  hasPedigree                                              Boolean             @default(false)
  pedigreeNumber                                           String?             @unique @db.VarChar(100)
  registrationNumber                                       String?             @unique @db.VarChar(100)
  microchipNumber                                          String?             @unique @db.VarChar(100)
  
  // Media
  images                                                   String[]            @default([])
  videos                                                   String[]            @default([])
  description                                              String?
  
  // Status
  isPublished                                              Boolean             @default(true)
  isActive                                                 Boolean             @default(true)
  healthScore                                              Float               @default(0)
  
  // Timestamps
  createdAt                                                DateTime            @default(now())
  updatedAt                                                DateTime            @updatedAt
  deletedAt                                                DateTime?
  
  // Relations
  owner                                                    users               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  breeding_requests_initiator                              breeding_requests[] @relation("breeding_requests_initiatorPetIdTopets")
  breeding_requests_target                                 breeding_requests[] @relation("breeding_requests_targetPetIdTopets")
  certifications                                           certifications[]
  clinic_bookings                                          clinic_bookings[]
  genetic_tests                                            genetic_tests[]
  health_records                                           health_records[]
  matches_initiator                                        matches[]           @relation("matches_initiatorPetIdTopets")
  matches_target                                           matches[]           @relation("matches_targetPetIdTopets")
  favorite_pets                                            favorite_pets[]
  
  // Indexes - Critical
  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([breed])
  @@index([breedingStatus])
  @@index([createdAt])
  @@index([gender])
  @@index([isPublished])
  @@index([species])
  @@index([isActive])
  @@index([healthScore])
  
  // Composite Indexes for Common Queries
  @@index([species, breed, isPublished])
  @@index([species, breedingStatus, isPublished, createdAt])
  @@index([gender, breedingStatus, healthScore])
}

// Favorite Pets System
model favorite_pets {
  id       String   @id @default(uuid())
  userId   String
  petId    String
  addedAt  DateTime @default(now())
  
  pet pets @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  @@unique([userId, petId])
  @@index([userId])
  @@index([petId])
  @@index([addedAt])
}

model health_records {
  id               String   @id @default(uuid())
  petId            String
  recordType       String   @db.VarChar(50)
  recordDate       DateTime
  veterinarianName String   @db.VarChar(150)
  clinicName       String?  @db.VarChar(150)
  details          String?
  certificateUrl   String?  @db.VarChar(500)
  nextCheckDate    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  pet pets @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  @@index([petId])
  @@index([recordDate])
  @@index([recordType])
  @@index([createdAt])
}

model certifications {
  id                 String            @id @default(uuid())
  petId              String
  type               CertificationType
  name               String            @db.VarChar(150)
  issueDate          DateTime
  expiryDate         DateTime?
  certificateUrl     String?           @db.VarChar(500)
  verificationStatus String            @default("VERIFIED") @db.VarChar(50)
  issuer             String?           @db.VarChar(200)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  pet pets @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  @@index([petId])
  @@index([type])
  @@index([verificationStatus])
  @@index([expiryDate])
}

model genetic_tests {
  id             String   @id @default(uuid())
  petId          String
  testName       String   @db.VarChar(150)
  provider       String   @db.VarChar(150)
  testDate       DateTime
  result         String
  certificateUrl String?  @db.VarChar(500)
  status         String   @default("COMPLETED") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  pet pets @relation(fields: [petId], references: [id], onDelete: Cascade)
  
  @@index([petId])
  @@index([testDate])
  @@index([status])
}

// ============================================================================
// BREEDING & MATCHING MODELS
// ============================================================================

model breeding_requests {
  id                                          String        @id @default(uuid())
  initiatorId                                 String
  initiatorPetId                              String
  targetUserId                                String
  targetPetId                                 String
  status                                      RequestStatus @default(PENDING)
  message                                     String?
  requestedDate                               DateTime      @default(now())
  preferredDate                               DateTime?
  estimatedDeliveryDate                       DateTime?
  rejectionReason                             String?
  cancellationReason                          String?
  viewedAt                                    DateTime?
  respondedAt                                 DateTime?
  createdAt                                   DateTime      @default(now())
  updatedAt                                   DateTime      @updatedAt
  
  initiator                                   users         @relation("breeding_requests_initiatorIdTousers", fields: [initiatorId], references: [id], onDelete: Cascade)
  initiatorPet                                pets          @relation("breeding_requests_initiatorPetIdTopets", fields: [initiatorPetId], references: [id], onDelete: Cascade)
  targetPet                                   pets          @relation("breeding_requests_targetPetIdTopets", fields: [targetPetId], references: [id], onDelete: Cascade)
  targetUser                                  users         @relation("breeding_requests_targetUserIdTousers", fields: [targetUserId], references: [id], onDelete: Cascade)
  matches                                     matches?
  messages                                    messages[]
  reviews                                     reviews[]
  
  @@unique([initiatorId, initiatorPetId, targetUserId, targetPetId])
  @@index([createdAt])
  @@index([initiatorId])
  @@index([status])
  @@index([targetUserId])
  @@index([requestedDate])
  @@index([status, createdAt])
  @@index([targetUserId, status, createdAt])
}

model matches {
  id                                String            @id @default(uuid())
  breedingRequestId                 String            @unique
  initiatorPetId                    String
  targetPetId                       String
  status                            MatchStatus       @default(PROPOSED)
  scheduledDate                     DateTime?
  completedDate                     DateTime?
  notes                             String?
  resultingOffspring                Int?
  offspringDetails                  Json?
  createdAt                         DateTime          @default(now())
  updatedAt                         DateTime          @updatedAt
  
  breedingRequest                   breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  initiatorPet                      pets              @relation("matches_initiatorPetIdTopets", fields: [initiatorPetId], references: [id], onDelete: Cascade)
  targetPet                         pets              @relation("matches_targetPetIdTopets", fields: [targetPetId], references: [id], onDelete: Cascade)
  
  @@index([completedDate])
  @@index([scheduledDate])
  @@index([status])
  @@index([createdAt])
  @@index([status, completedDate])
}

// ============================================================================
// MESSAGING & COMMUNICATION MODELS
// ============================================================================

model messages {
  id                                String             @id @default(uuid())
  senderId                          String
  recipientId                       String
  breedingRequestId                 String?
  content                           String
  attachments                        String[]          @default([])
  status                            MessageStatus      @default(SENT)
  isRead                            Boolean            @default(false)
  readAt                            DateTime?
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime           @updatedAt
  
  breedingRequest                   breeding_requests? @relation(fields: [breedingRequestId], references: [id], onDelete: SetNull)
  sender                            users              @relation("messages_senderIdTousers", fields: [senderId], references: [id], onDelete: Cascade)
  recipient                         users              @relation("messages_recipientIdTousers", fields: [recipientId], references: [id], onDelete: Cascade)
  
  @@index([breedingRequestId])
  @@index([createdAt])
  @@index([isRead])
  @@index([recipientId])
  @@index([senderId])
  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, isRead, createdAt])
}

// ============================================================================
// REVIEW & FEEDBACK MODELS
// ============================================================================

model reviews {
  id                              String            @id @default(uuid())
  reviewerId                      String
  revieweeId                      String
  breedingRequestId               String
  rating                          Int
  comment                         String?
  helpfulCount                    Int               @default(0)
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime          @updatedAt
  
  breedingRequest                 breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  reviewee                         users             @relation("reviews_revieweeIdTousers", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer                         users             @relation("reviews_reviewerIdTousers", fields: [reviewerId], references: [id], onDelete: Cascade)
  
  @@unique([reviewerId, breedingRequestId])
  @@index([createdAt])
  @@index([rating])
  @@index([revieweeId])
  @@index([reviewerId])
}

// ============================================================================
// CLINIC & VETERINARY SERVICES MODELS
// ============================================================================

model clinic {
  id              String            @id @default(uuid())
  name            String            @db.VarChar(200)
  description     String?
  phone           String            @db.VarChar(20)
  email           String            @db.VarChar(255)
  address         String            @db.VarChar(500)
  city            String            @db.VarChar(100)
  country         String            @db.VarChar(100)
  latitude        Float?
  longitude       Float?
  operatingHours  Json
  isActive        Boolean           @default(true)
  rating          Float             @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  bookings        clinic_bookings[]
  services        clinic_services[]
  
  @@index([city])
  @@index([isActive])
  @@index([createdAt])
}

model clinic_services {
  id              String            @id @default(uuid())
  clinicId        String
  type            ServiceType
  name            String            @db.VarChar(200)
  description     String?
  duration        Int
  price           Float
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  clinic          clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  bookings        clinic_bookings[]
  
  @@index([clinicId])
  @@index([type])
  @@index([isActive])
}

model clinic_bookings {
  id              String          @id @default(uuid())
  clinicId        String
  serviceId       String
  userId          String
  petId           String
  bookingDate     DateTime
  timeSlot        String          @db.VarChar(20)
  status          BookingStatus   @default(PENDING)
  userNotes       String?
  adminNotes      String?
  certificate     String?         @db.VarChar(500)
  resultNotes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  clinic          clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user            users           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet             pets            @relation(fields: [petId], references: [id], onDelete: Cascade)
  service         clinic_services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  @@unique([clinicId, bookingDate, serviceId, timeSlot])
  @@index([bookingDate])
  @@index([petId])
  @@index([status])
  @@index([userId])
  @@index([clinicId])
  @@index([status, bookingDate])
}

// ============================================================================
// ADMIN & MODERATION MODELS
// ============================================================================

model reports {
  id                                  String       @id @default(uuid())
  reporterUserId                      String
  reportedUserId                      String?
  reportedPetId                       String?
  reportedContentId                   String?
  contentType                         String       @db.VarChar(50)
  reason                              ReportReason
  description                         String
  status                              ReportStatus @default(PENDING)
  resolvedBy                          String?
  resolutionNotes                     String?
  resolvedAt                          DateTime?
  createdAt                           DateTime     @default(now())
  updatedAt                           DateTime     @updatedAt
  
  reportedUser                        users?       @relation("reports_reportedUserIdTousers", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reporter                            users        @relation("reports_reporterUserIdTousers", fields: [reporterUserId], references: [id], onDelete: Cascade)
  
  @@index([createdAt])
  @@index([reportedUserId])
  @@index([reporterUserId])
  @@index([status])
  @@index([reason])
  @@index([status, createdAt])
}

model audit_logs {
  id           String   @id @default(uuid())
  adminId      String
  action       String   @db.VarChar(100)
  targetUserId String?
  targetPetId  String?
  description  String
  changes      Json?
  ipAddress    String?  @db.VarChar(50)
  userAgent    String?
  createdAt    DateTime @default(now())
  
  admin        users    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  
  @@index([action])
  @@index([adminId])
  @@index([createdAt])
  @@index([targetUserId])
  @@index([action, createdAt])
}

// ============================================================================
// SUPPORT & TICKETING MODELS
// ============================================================================

model support_tickets {
  id        String         @id @default(uuid())
  userId    String?
  name      String
  email     String
  subject   String
  category  TicketCategory
  message   String
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(OPEN)
  replies   Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  closedAt  DateTime?
  
  user      users?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([createdAt])
  @@index([email])
  @@index([status])
  @@index([userId])
  @@index([priority, status])
}

// ============================================================================
// SUBSCRIPTION & PAYMENT MODELS
// ============================================================================

model subscriptions {
  id                   String             @id @default(uuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  startDate            DateTime           @default(now())
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  cancelledAt          DateTime?
  petsListedCount      Int                @default(0)
  requestsSentCount    Int                @default(0)
  requestsSentMonth    String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  
  user users @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([userId])
  @@index([tier])
  @@index([currentPeriodEnd])
}

// ============================================================================
// SYSTEM & CONFIGURATION MODELS
// ============================================================================

model system_settings {
  id                     String   @id @unique
  maintenanceMode        Boolean  @default(false)
  maintenanceMessage     String?
  enableUserRegistration Boolean  @default(true)
  enableBreedingRequests Boolean  @default(true)
  enableMessaging        Boolean  @default(true)
  maxWarningsBeforeBan   Int      @default(3)
  autoDeleteReportsAfter Int      @default(90)
  autoDeleteTokensAfter  Int      @default(30)
  maxLoginAttempts       Int      @default(5)
  loginLockoutDuration   Int      @default(15)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ============================================================================
// ENUMS
// ============================================================================

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED_USER
  CANCELLED_ADMIN
  NO_SHOW
}

enum BreedingStatus {
  AVAILABLE
  NOT_AVAILABLE
  RETIRED
}

enum CertificationType {
  PEDIGREE
  GENETIC_TEST
  HEALTH_CHECK
  VACCINATION
  MICROCHIP
  REGISTRATION
  OTHER
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum MatchStatus {
  PROPOSED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum ReportReason {
  INAPPROPRIATE_CONTENT
  HARASSMENT
  SPAM
  FRAUD
  SCAM
  DANGEROUS_BEHAVIOR
  ANIMAL_ABUSE
  FAKE_PROFILE
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  REJECTED
  APPEALED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum Role {
  USER
  BREEDER
  ADMIN
  MODERATOR
  SUPER_ADMIN
}

enum ServiceType {
  HEALTH_CHECKUP
  VACCINATION
  GENETIC_TEST
  MICROCHIP
  CERTIFICATION
  EMERGENCY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAYMENT_FAILED
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum TicketCategory {
  TECHNICAL
  ACCOUNT
  PAYMENT
  MATCHING
  SAFETY
  FEEDBACK
  OTHER
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  REPLIED
  CLOSED
}
