/**
 * Enhanced Prisma Schema with Encrypted Fields
 * This schema shows the changes needed for field-level encryption
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ENCRYPTED SCHEMA CHANGES
// ========================================

model users {
  id                                                      String              @id
  email                                                   String              @unique @db.VarChar(255)
  password                                                String              // Hashed with bcrypt
  firstName                                               String              @db.VarChar(100)
  lastName                                                String              @db.VarChar(100)
  
  // ENCRYPTED FIELDS
  phone                                                   String?             @db.VarChar(20)      // Encrypted
  avatar                                                  String?             @db.VarChar(500)      // Encrypted URL
  bio                                                     String?                                 // Encrypted
  address                                                 String?             @db.VarChar(500)      // Encrypted
  city                                                    String?             @db.VarChar(100)      // Encrypted
  country                                                 String?             @db.VarChar(100)      // Encrypted
  location                                                Json?                                   // Encrypted GPS coordinates
  
  // SEARCHABLE HASHES (for encrypted fields)
  phone_hash                                              String?             @db.VarChar(64)      // Hash of phone for searching
  city_hash                                               String?             @db.VarChar(64)      // Hash of city for searching
  country_hash                                            String?             @db.VarChar(64)      // Hash of country for searching
  
  // UNENCRYPTED FIELDS
  role                                                    Role                @default(USER)
  isVerified                                              Boolean             @default(false)
  verificationToken                                       String?             @unique @db.VarChar(255)
  verificationExpiresAt                                   DateTime?
  rating                                                  Float               @default(0)
  totalMatches                                            Int                 @default(0)
  totalReviews                                            Int                 @default(0)
  subscriptionTier                                        SubscriptionTier    @default(FREE)
  createdAt                                               DateTime            @default(now())
  updatedAt                                               DateTime
  
  // Relations
  breeding_requests_breeding_requests_initiatorIdTousers breeding_requests[]
  breeding_requests_breeding_requests_targetUserIdTousers breeding_requests[]
  pets                                                    pets[]
  refresh_tokens                                          refresh_tokens[]
  reviews                                                 reviews[]
  subscriptions                                           subscriptions[]
  support_tickets                                         support_tickets?
  messages_messages_recipientIdTousers                   messages[]
  messages_messages_senderIdTousers                       messages[]
  clinic_bookings                                          clinic_bookings[]

  @@index([city_hash])
  @@index([country_hash])
  @@index([phone_hash])
}

model pets {
  id                                                       String              @id
  ownerId                                                  String
  name                                                     String              @db.VarChar(100)
  species                                                  String              @db.VarChar(50)
  breed                                                    String              @db.VarChar(100)
  gender                                                   Gender
  dateOfBirth                                              DateTime?
  weight                                                   Float?
  height                                                   Float?
  color                                                    String?             @db.VarChar(100)
  
  // ENCRYPTED FIELDS
  distinctiveFeatures                                      String?                                 // Encrypted
  healthConditions                                         String?                                 // Encrypted
  microchipNumber                                          String?             @unique @db.VarChar(100)  // Encrypted
  registrationNumber                                       String?             @unique @db.VarChar(100)  // Encrypted
  pedigreeNumber                                           String?             @unique @db.VarChar(100)  // Encrypted
  
  // SEARCHABLE HASHES
  microchip_hash                                           String?             @db.VarChar(64)      // Hash for searching
  registration_hash                                        String?             @db.VarChar(64)      // Hash for searching
  pedigree_hash                                           String?             @db.VarChar(64)      // Hash for searching
  
  // UNENCRYPTED FIELDS
  isVaccinated                                             Boolean             @default(false)
  isNeutered                                               Boolean             @default(false)
  lastHealthCheckDate                                      DateTime?
  nextVaccinationDate                                      DateTime?
  breedingStatus                                           BreedingStatus      @default(NOT_AVAILABLE)
  breedingPrice                                            Float?
  nextAvailableDate                                        DateTime?
  hasPedigree                                              Boolean             @default(false)
  images                                                   String[]            @default([])
  videos                                                   String[]            @default([])
  description                                              String?
  isPublished                                              Boolean             @default(true)
  isActive                                                 Boolean             @default(true)
  createdAt                                                DateTime            @default(now())
  updatedAt                                                DateTime
  deletedAt                                                DateTime?
  
  // Relations
  breeding_requests_breeding_requests_initiatorPetIdTopets breeding_requests[]
  breeding_requests_breeding_requests_targetPetIdTopets    breeding_requests[]
  certifications                                           certifications[]
  clinic_bookings                                          clinic_bookings[]
  genetic_tests                                            genetic_tests[]
  health_records                                           health_records[]
  matches_matches_initiatorPetIdTopets                     matches[]
  matches_matches_targetPetIdTopets                        matches[]
  users                                                    users               @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, name])
  @@index([breed])
  @@index([breedingStatus])
  @@index([createdAt])
  @@index([gender])
  @@index([isPublished])
  @@index([ownerId])
  @@index([species])
  @@index([microchip_hash])
  @@index([registration_hash])
  @@index([pedigree_hash])
}

model health_records {
  id               String   @id
  petId            String
  
  // ENCRYPTED FIELDS
  details          String?  @db.Text           // Encrypted medical details
  veterinarianName String   @db.VarChar(150)   // Encrypted
  clinicName       String?  @db.VarChar(150)   // Encrypted
  certificateUrl   String?  @db.VarChar(500)   // Encrypted URL
  
  // SEARCHABLE HASHES
  vet_hash         String?  @db.VarChar(64)    // Hash of vet name for searching
  clinic_hash      String?  @db.VarChar(64)    // Hash of clinic name for searching
  
  // UNENCRYPTED FIELDS
  recordType       String   @db.VarChar(50)
  recordDate       DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  
  // Relations
  pets             pets     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([recordDate])
  @@index([recordType])
  @@index([vet_hash])
  @@index([clinic_hash])
}

model clinic_bookings {
  id              String          @id
  clinicId        String
  serviceId       String
  petId           String
  userId          String
  bookingDate     DateTime
  timeSlot        String          @db.VarChar(20)
  status          BookingStatus   @default(PENDING)
  
  // ENCRYPTED FIELDS
  userNotes       String?         @db.Text        // Encrypted user notes
  adminNotes      String?         @db.Text        // Encrypted admin notes
  certificate     String?         @db.VarChar(500) // Encrypted certificate URL
  resultNotes     String?         @db.Text        // Encrypted result notes
  
  // UNENCRYPTED FIELDS
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  completedAt     DateTime?
  cancelledAt     DateTime?
  
  // Relations
  clinic          clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pets            pets            @relation(fields: [petId], references: [id], onDelete: Cascade)
  clinic_services clinic_services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  users           users           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, bookingDate, timeSlot])
  @@index([bookingDate])
  @@index([petId])
  @@index([status])
  @@index([userId])
}

model genetic_tests {
  id             String   @id
  petId          String
  testName       String   @db.VarChar(150)
  provider       String   @db.VarChar(150)
  testDate       DateTime
  
  // ENCRYPTED FIELDS
  result         String   @db.Text           // Encrypted test results
  certificateUrl String?  @db.VarChar(500)   // Encrypted certificate URL
  
  // SEARCHABLE HASHES
  provider_hash   String?  @db.VarChar(64)    // Hash of provider for searching
  
  // UNENCRYPTED FIELDS
  status         String   @default("COMPLETED") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  
  // Relations
  pets           pets     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([testDate])
  @@index([provider_hash])
}

model certifications {
  id                 String            @id
  petId              String
  type               CertificationType
  name               String            @db.VarChar(150)
  issueDate          DateTime
  expiryDate         DateTime?
  
  // ENCRYPTED FIELDS
  certificateUrl     String?           @db.VarChar(500)  // Encrypted certificate URL
  issuer             String?           @db.VarChar(200)  // Encrypted issuer name
  
  // SEARCHABLE HASHES
  issuer_hash        String?           @db.VarChar(64)    // Hash of issuer for searching
  
  // UNENCRYPTED FIELDS
  verificationStatus String            @default("VERIFIED") @db.VarChar(50)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  
  // Relations
  pets               pets              @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([type])
  @@index([verificationStatus])
  @@index([issuer_hash])
}

model messages {
  id                                String             @id
  senderId                          String
  recipientId                       String
  breedingRequestId                 String?
  
  // ENCRYPTED FIELDS
  content                           String             @db.Text         // Encrypted message content
  
  // SEARCHABLE HASHES
  content_hash                      String?            @db.VarChar(64)  // Hash of content for searching
  
  // UNENCRYPTED FIELDS
  status                            MessageStatus      @default(SENT)
  isRead                            Boolean            @default(false)
  readAt                            DateTime?
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime
  
  // Relations
  breeding_requests                 breeding_requests? @relation(fields: [breedingRequestId], references: [id])
  users_messages_recipientIdTousers users              @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  users_messages_senderIdTousers    users              @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([breedingRequestId])
  @@index([createdAt])
  @@index([isRead])
  @@index([recipientId])
  @@index([senderId])
  @@index([content_hash])
}

model support_tickets {
  id        String         @id
  userId    String?
  name      String
  email     String
  subject   String
  category  TicketCategory
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(OPEN)
  
  // ENCRYPTED FIELDS
  message   String         @db.Text         // Encrypted ticket message
  replies   Json?                            // Encrypted replies
  
  // SEARCHABLE HASHES
  message_hash String?        @db.VarChar(64)  // Hash of message for searching
  
  // UNENCRYPTED FIELDS
  createdAt DateTime       @default(now())
  updatedAt DateTime
  
  // Relations
  users     users?         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([email])
  @@index([status])
  @@index([userId])
  @@index([message_hash])
}

// ========================================
// OTHER MODELS (UNCHANGED)
// ========================================

model breeding_requests {
  id                                          String        @id
  initiatorId                                 String
  initiatorPetId                              String
  targetUserId                                String
  targetPetId                                 String
  status                                      RequestStatus @default(PENDING)
  message                                     String?       @db.Text
  requestedDate                               DateTime      @default(now())
  preferredDate                               DateTime?
  estimatedDeliveryDate                       DateTime?
  createdAt                                   DateTime      @default(now())
  updatedAt                                   DateTime
  users_breeding_requests_initiatorIdTousers  users         @relation("breeding_requests_initiatorIdTousers", fields: [initiatorId], references: [id], onDelete: Cascade)
  pets_breeding_requests_initiatorPetIdTopets pets          @relation("breeding_requests_initiatorPetIdTopets", fields: [initiatorPetId], references: [id], onDelete: Cascade)
  pets_breeding_requests_targetPetIdTopets    pets          @relation("breeding_requests_targetPetIdTopets", fields: [targetPetId], references: [id], onDelete: Cascade)
  users_breeding_requests_targetUserIdTousers users         @relation("breeding_requests_targetUserIdTousers", fields: [targetUserId], references: [id], onDelete: Cascade)
  matches                                     matches?
  messages                                    messages[]
  reviews                                     reviews[]

  @@unique([initiatorId, initiatorPetId, targetUserId, targetPetId])
  @@index([createdAt])
  @@index([initiatorId])
  @@index([status])
  @@index([targetUserId])
}

model clinic {
  id              String            @id
  name            String            @db.VarChar(200)
  description     String?
  phone           String            @db.VarChar(20)
  email           String            @db.VarChar(255)
  address         String            @db.VarChar(500)
  city            String            @db.VarChar(100)
  country         String            @db.VarChar(100)
  operatingHours  Json
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  clinic_bookings clinic_bookings[]
  clinic_services clinic_services[]
}

model clinic_services {
  id              String            @id
  clinicId        String
  type            ServiceType
  name            String            @db.VarChar(200)
  description     String?
  duration        Int
  price           Float
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  clinic_bookings clinic_bookings[]
  clinic          clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([type])
}

model matches {
  id                                String            @id
  breedingRequestId                 String            @unique
  initiatorPetId                    String
  targetPetId                       String
  status                            MatchStatus       @default(PROPOSED)
  scheduledDate                     DateTime?
  completedDate                     DateTime?
  notes                             String?
  resultingOffspring                Int?
  createdAt                         DateTime          @default(now())
  updatedAt                         DateTime
  breeding_requests                 breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  pets_matches_initiatorPetIdTopets pets              @relation("matches_initiatorPetIdTopets", fields: [initiatorPetId], references: [id])
  pets_matches_targetPetIdTopets    pets              @relation("matches_targetPetIdTopets", fields: [targetPetId], references: [id])

  @@index([completedDate])
  @@index([scheduledDate])
  @@index([status])
}

model refresh_tokens {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model reviews {
  id                              String            @id
  reviewerId                      String
  revieweeId                      String
  breedingRequestId               String
  rating                          Int
  comment                         String?
  helpfulCount                    Int               @default(0)
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime
  breeding_requests               breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  users_reviews_revieweeIdTousers users             @relation("reviews_revieweeIdTousers", fields: [revieweeId], references: [id], onDelete: Cascade)
  users_reviews_reviewerIdTousers users             @relation("reviews_reviewerIdTousers", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, breedingRequestId])
  @@index([createdAt])
  @@index([rating])
  @@index([revieweeId])
}

model subscriptions {
  id                   String             @id
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  startDate            DateTime           @default(now())
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  cancelledAt          DateTime?
  petsListedCount      Int                @default(0)
  requestsSentCount    Int                @default(0)
  requestsSentMonth    String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  users                users              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

// ========================================
// ENUMS
// ========================================

enum Role {
  USER
  ADMIN
  VETERINARIAN
  BREEDER
}

enum Gender {
  MALE
  FEMALE
}

enum BreedingStatus {
  NOT_AVAILABLE
  AVAILABLE
  PENDING
  BREEDING
  RETIRED
}

enum SubscriptionTier {
  FREE
  BASIC
  PREMIUM
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ServiceType {
  CHECKUP
  VACCINATION
  SURGERY
  GROOMING
  TRAINING
  BOARDING
  EMERGENCY
}

enum CertificationType {
  HEALTH
  VACCINATION
  GENETIC
  PEDIGREE
  TRAINING
  BREEDING
}

enum TicketCategory {
  GENERAL
  TECHNICAL
  BILLING
  ACCOUNT
  SAFETY
  FEATURE_REQUEST
  BUG_REPORT
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}
