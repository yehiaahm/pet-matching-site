generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id           String   @id
  adminId      String
  action       String   @db.VarChar(100)
  targetUserId String?
  targetPetId  String?
  description  String
  changes      Json?
  ipAddress    String?  @db.VarChar(50)
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([action])
  @@index([adminId])
  @@index([createdAt])
  @@index([targetUserId])
}

model breeding_requests {
  id                                          String        @id
  initiatorId                                 String
  initiatorPetId                              String
  targetUserId                                String
  targetPetId                                 String
  status                                      RequestStatus @default(PENDING)
  message                                     String?
  requestedDate                               DateTime      @default(now())
  preferredDate                               DateTime?
  estimatedDeliveryDate                       DateTime?
  createdAt                                   DateTime      @default(now())
  updatedAt                                   DateTime
  users_breeding_requests_initiatorIdTousers  users         @relation("breeding_requests_initiatorIdTousers", fields: [initiatorId], references: [id], onDelete: Cascade)
  pets_breeding_requests_initiatorPetIdTopets pets          @relation("breeding_requests_initiatorPetIdTopets", fields: [initiatorPetId], references: [id], onDelete: Cascade)
  pets_breeding_requests_targetPetIdTopets    pets          @relation("breeding_requests_targetPetIdTopets", fields: [targetPetId], references: [id], onDelete: Cascade)
  users_breeding_requests_targetUserIdTousers users         @relation("breeding_requests_targetUserIdTousers", fields: [targetUserId], references: [id], onDelete: Cascade)
  matches                                     matches?
  messages                                    messages[]
  reviews                                     reviews[]

  @@unique([initiatorId, initiatorPetId, targetUserId, targetPetId])
  @@index([createdAt])
  @@index([initiatorId])
  @@index([status])
  @@index([targetUserId])
}

model certifications {
  id                 String            @id
  petId              String
  type               CertificationType
  name               String            @db.VarChar(150)
  issueDate          DateTime
  expiryDate         DateTime?
  certificateUrl     String?           @db.VarChar(500)
  verificationStatus String            @default("VERIFIED") @db.VarChar(50)
  issuer             String?           @db.VarChar(200)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  pets               pets              @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([type])
  @@index([verificationStatus])
}

model clinic {
  id              String            @id
  name            String            @db.VarChar(200)
  description     String?
  phone           String            @db.VarChar(20)
  email           String            @db.VarChar(255)
  address         String            @db.VarChar(500)
  city            String            @db.VarChar(100)
  country         String            @db.VarChar(100)
  operatingHours  Json
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  clinic_bookings clinic_bookings[]
  clinic_services clinic_services[]
}

model clinic_bookings {
  id              String          @id
  clinicId        String
  serviceId       String
  petId           String
  userId          String
  bookingDate     DateTime
  timeSlot        String          @db.VarChar(20)
  status          BookingStatus   @default(PENDING)
  userNotes       String?
  adminNotes      String?
  certificate     String?         @db.VarChar(500)
  resultNotes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  completedAt     DateTime?
  cancelledAt     DateTime?
  clinic          clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pets            pets            @relation(fields: [petId], references: [id], onDelete: Cascade)
  clinic_services clinic_services @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  users           users           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, bookingDate, timeSlot])
  @@index([bookingDate])
  @@index([petId])
  @@index([status])
  @@index([userId])
}

model clinic_services {
  id              String            @id
  clinicId        String
  type            ServiceType
  name            String            @db.VarChar(200)
  description     String?
  duration        Int
  price           Float
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  clinic_bookings clinic_bookings[]
  clinic          clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([type])
}

model genetic_tests {
  id             String   @id
  petId          String
  testName       String   @db.VarChar(150)
  provider       String   @db.VarChar(150)
  testDate       DateTime
  result         String
  certificateUrl String?  @db.VarChar(500)
  status         String   @default("COMPLETED") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  pets           pets     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([testDate])
}

model health_records {
  id               String   @id
  petId            String
  recordType       String   @db.VarChar(50)
  recordDate       DateTime
  veterinarianName String   @db.VarChar(150)
  clinicName       String?  @db.VarChar(150)
  details          String?
  certificateUrl   String?  @db.VarChar(500)
  createdAt        DateTime @default(now())
  updatedAt        DateTime
  pets             pets     @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([recordDate])
  @@index([recordType])
}

model matches {
  id                                String            @id
  breedingRequestId                 String            @unique
  initiatorPetId                    String
  targetPetId                       String
  status                            MatchStatus       @default(PROPOSED)
  scheduledDate                     DateTime?
  completedDate                     DateTime?
  notes                             String?
  resultingOffspring                Int?
  createdAt                         DateTime          @default(now())
  updatedAt                         DateTime
  breeding_requests                 breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  pets_matches_initiatorPetIdTopets pets              @relation("matches_initiatorPetIdTopets", fields: [initiatorPetId], references: [id])
  pets_matches_targetPetIdTopets    pets              @relation("matches_targetPetIdTopets", fields: [targetPetId], references: [id])

  @@index([completedDate])
  @@index([scheduledDate])
  @@index([status])
}

model messages {
  id                                String             @id
  senderId                          String
  recipientId                       String
  breedingRequestId                 String?
  content                           String
  status                            MessageStatus      @default(SENT)
  isRead                            Boolean            @default(false)
  readAt                            DateTime?
  createdAt                         DateTime           @default(now())
  updatedAt                         DateTime
  breeding_requests                 breeding_requests? @relation(fields: [breedingRequestId], references: [id])
  users_messages_recipientIdTousers users              @relation("messages_recipientIdTousers", fields: [recipientId], references: [id], onDelete: Cascade)
  users_messages_senderIdTousers    users              @relation("messages_senderIdTousers", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([breedingRequestId])
  @@index([createdAt])
  @@index([isRead])
  @@index([recipientId])
  @@index([senderId])
}

model notifications {
  id        String               @id
  userId    String?
  title     String               @db.VarChar(200)
  message   String
  type      NotificationType     @default(INFO)
  priority  NotificationPriority @default(MEDIUM)
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())
  users     users?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([isRead])
  @@index([priority])
  @@index([type])
  @@index([userId])
}

model pets {
  id                                                       String               @id
  ownerId                                                  String
  name                                                     String               @db.VarChar(100)
  species                                                  String               @db.VarChar(50)
  breed                                                    String               @db.VarChar(100)
  gender                                                   Gender
  dateOfBirth                                              DateTime?
  weight                                                   Float?
  height                                                   Float?
  color                                                    String?              @db.VarChar(100)
  distinctiveFeatures                                      String?
  isVaccinated                                             Boolean              @default(false)
  isNeutered                                               Boolean              @default(false)
  healthConditions                                         String?
  lastHealthCheckDate                                      DateTime?
  nextVaccinationDate                                      DateTime?
  breedingStatus                                           BreedingStatus       @default(NOT_AVAILABLE)
  breedingPrice                                            Float?
  nextAvailableDate                                        DateTime?
  hasPedigree                                              Boolean              @default(false)
  pedigreeNumber                                           String?              @unique @db.VarChar(100)
  registrationNumber                                       String?              @unique @db.VarChar(100)
  microchipNumber                                          String?              @unique @db.VarChar(100)
  images                                                   String[]             @default([])
  videos                                                   String[]             @default([])
  description                                              String?
  isPublished                                              Boolean              @default(true)
  isActive                                                 Boolean              @default(true)
  createdAt                                                DateTime             @default(now())
  updatedAt                                                DateTime
  deletedAt                                                DateTime?
  breeding_requests_breeding_requests_initiatorPetIdTopets breeding_requests[]  @relation("breeding_requests_initiatorPetIdTopets")
  breeding_requests_breeding_requests_targetPetIdTopets    breeding_requests[]  @relation("breeding_requests_targetPetIdTopets")
  certifications                                           certifications[]
  clinic_bookings                                          clinic_bookings[]
  genetic_tests                                            genetic_tests[]
  health_records                                           health_records[]
  matches_matches_initiatorPetIdTopets                     matches[]            @relation("matches_initiatorPetIdTopets")
  matches_matches_targetPetIdTopets                        matches[]            @relation("matches_targetPetIdTopets")
  users                                                    users                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  user_pet_onboarding                                      user_pet_onboarding?

  @@unique([ownerId, name])
  @@index([breed])
  @@index([breedingStatus])
  @@index([createdAt])
  @@index([gender])
  @@index([isPublished])
  @@index([ownerId])
  @@index([species])
}

model refresh_tokens {
  id        String   @id
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model reports {
  id                                  String       @id
  reporterUserId                      String
  reportedUserId                      String?
  reportedPetId                       String?
  reportedContentId                   String?
  contentType                         String       @db.VarChar(50)
  reason                              ReportReason
  description                         String
  status                              ReportStatus @default(PENDING)
  resolvedBy                          String?
  resolutionNotes                     String?
  resolvedAt                          DateTime?
  createdAt                           DateTime     @default(now())
  updatedAt                           DateTime
  users_reports_reportedUserIdTousers users?       @relation("reports_reportedUserIdTousers", fields: [reportedUserId], references: [id])
  users_reports_reporterUserIdTousers users        @relation("reports_reporterUserIdTousers", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([reportedUserId])
  @@index([reporterUserId])
  @@index([status])
}

model reviews {
  id                              String            @id
  reviewerId                      String
  revieweeId                      String
  breedingRequestId               String
  rating                          Int
  comment                         String?
  helpfulCount                    Int               @default(0)
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime
  breeding_requests               breeding_requests @relation(fields: [breedingRequestId], references: [id], onDelete: Cascade)
  users_reviews_revieweeIdTousers users             @relation("reviews_revieweeIdTousers", fields: [revieweeId], references: [id], onDelete: Cascade)
  users_reviews_reviewerIdTousers users             @relation("reviews_reviewerIdTousers", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, breedingRequestId])
  @@index([createdAt])
  @@index([rating])
  @@index([revieweeId])
}

model subscriptions {
  id                   String             @id
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  startDate            DateTime           @default(now())
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAt             DateTime?
  cancelledAt          DateTime?
  petsListedCount      Int                @default(0)
  requestsSentCount    Int                @default(0)
  requestsSentMonth    String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime
  users                users              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

model support_tickets {
  id        String         @id
  userId    String?
  name      String
  email     String
  subject   String
  category  TicketCategory
  message   String
  priority  TicketPriority @default(NORMAL)
  status    TicketStatus   @default(OPEN)
  replies   Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime
  users     users?         @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([email])
  @@index([status])
  @@index([userId])
}

model system_announcements {
  id        String   @id
  title     String   @db.VarChar(200)
  message   String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([active])
  @@index([createdAt])
}

model system_settings {
  id                     String   @id @unique
  maintenanceMode        Boolean  @default(false)
  maintenanceMessage     String?
  enableUserRegistration Boolean  @default(true)
  enableBreedingRequests Boolean  @default(true)
  enableMessaging        Boolean  @default(true)
  maxWarningsBeforeBan   Int      @default(3)
  autoDeleteReportsAfter Int      @default(90)
  updatedAt              DateTime
}

model user_pet_onboarding {
  id          String              @id
  userId      String              @unique
  firstPetId  String?             @unique
  status      PetOnboardingStatus @default(PENDING_PET)
  requiredPet Boolean             @default(true)
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime
  pets        pets?               @relation(fields: [firstPetId], references: [id])
  users       users               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([userId, status])
}

model users {
  id                                                      String               @id
  email                                                   String               @unique @db.VarChar(255)
  password                                                String
  firstName                                               String               @db.VarChar(100)
  lastName                                                String               @db.VarChar(100)
  phone                                                   String?              @db.VarChar(20)
  avatar                                                  String?              @db.VarChar(500)
  bio                                                     String?
  address                                                 String?              @db.VarChar(500)
  city                                                    String?              @db.VarChar(100)
  country                                                 String?              @db.VarChar(100)
  role                                                    Role                 @default(USER)
  isVerified                                              Boolean              @default(false)
  verificationToken                                       String?              @unique @db.VarChar(255)
  verificationExpiresAt                                   DateTime?
  rating                                                  Float                @default(0)
  totalMatches                                            Int                  @default(0)
  totalReviews                                            Int                  @default(0)
  subscriptionTier                                        SubscriptionTier     @default(FREE)
  createdAt                                               DateTime             @default(now())
  updatedAt                                               DateTime
  deletedAt                                               DateTime?
  bannedAt                                                DateTime?
  bannedBy                                                String?
  bannedReason                                            String?
  isBanned                                                Boolean              @default(false)
  lastWarningAt                                           DateTime?
  warnings                                                Int                  @default(0)
  breeding_requests_breeding_requests_initiatorIdTousers  breeding_requests[]  @relation("breeding_requests_initiatorIdTousers")
  breeding_requests_breeding_requests_targetUserIdTousers breeding_requests[]  @relation("breeding_requests_targetUserIdTousers")
  clinic_bookings                                         clinic_bookings[]
  messages_messages_recipientIdTousers                    messages[]           @relation("messages_recipientIdTousers")
  messages_messages_senderIdTousers                       messages[]           @relation("messages_senderIdTousers")
  notifications                                           notifications[]
  pets                                                    pets[]
  refresh_tokens                                          refresh_tokens[]
  reports_reports_reportedUserIdTousers                   reports[]            @relation("reports_reportedUserIdTousers")
  reports_reports_reporterUserIdTousers                   reports[]            @relation("reports_reporterUserIdTousers")
  reviews_reviews_revieweeIdTousers                       reviews[]            @relation("reviews_revieweeIdTousers")
  reviews_reviews_reviewerIdTousers                       reviews[]            @relation("reviews_reviewerIdTousers")
  subscriptions                                           subscriptions?
  support_tickets                                         support_tickets[]
  user_pet_onboarding                                     user_pet_onboarding?

  @@index([city])
  @@index([createdAt])
  @@index([email])
  @@index([isBanned])
  @@index([isVerified])
  @@index([role])
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  profileImage  String?
  role          String   @default("user")
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pets                  Pet[]
  sentMessages          Message[]          @relation("SentMessages")
  conversationsAsUser1  Conversation[]     @relation("ConversationUser1")
  conversationsAsUser2  Conversation[]     @relation("ConversationUser2")
  payments              Payment[]
  subscriptions         UserSubscription[]
  verificationCodes     VerificationCode[]
  analyticsEvents       AnalyticsEvent[]
  gpsTracks             GpsTrack[]
  sellerAccount         SellerAccount?
  cart                  Cart?
  orders                Order[]

  @@index([createdAt])
  @@index([role])
  @@map("app_users")
}

model SellerAccount {
  id             String    @id @default(uuid())
  userId         String    @unique
  storeName      String
  description    String?
  commissionRate Float     @default(10)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products   Product[]
  orderItems OrderItem[]

  @@index([isActive])
  @@index([createdAt])
  @@map("app_seller_accounts")
}

model Product {
  id          String              @id @default(uuid())
  sellerId    String
  name        String
  description String?
  price       Float
  category    MarketplaceCategory
  stock       Int                 @default(0)
  images      String[]            @default([])
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  seller     SellerAccount @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([sellerId])
  @@index([category])
  @@index([createdAt])
  @@map("app_products")
}

model Cart {
  id        String   @id @default(uuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([createdAt])
  @@map("app_carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([productId])
  @@index([createdAt])
  @@map("app_cart_items")
}

model Order {
  id                String                 @id @default(uuid())
  userId            String
  status            MarketplaceOrderStatus @default(pending)
  totalAmount       Float                  @default(0)
  commissionAmount  Float                  @default(0)
  sellerPayoutAmount Float                 @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("app_orders")
}

model OrderItem {
  id               String   @id @default(uuid())
  orderId          String
  productId        String
  sellerId         String
  quantity         Int
  unitPrice        Float
  lineTotal        Float
  commissionRate   Float
  commissionAmount Float
  sellerEarning    Float
  createdAt        DateTime @default(now())

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller  SellerAccount @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
  @@map("app_order_items")
}

model Pet {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  type        String
  breed       String
  gender      String
  age         Int
  description String?
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images PetImage[]
  healthRecords HealthRecord[]

  sentRequests MatchRequest[] @relation("SenderPet")
  targetRequests MatchRequest[] @relation("TargetPet")
  aiMatchesAsPet1 AIMatch[] @relation("AIMatchPet1")
  aiMatchesAsPet2 AIMatch[] @relation("AIMatchPet2")
  gpsTracks GpsTrack[]

  @@index([ownerId])
  @@index([type, breed])
  @@index([createdAt])
  @@map("app_pets")
}

model PetImage {
  id     String @id @default(uuid())
  petId  String
  url    String

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("app_pet_images")
}

model MatchRequest {
  id          String   @id @default(uuid())
  senderPetId String
  targetPetId String
  message     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  senderPet Pet @relation("SenderPet", fields: [senderPetId], references: [id], onDelete: Cascade)
  targetPet Pet @relation("TargetPet", fields: [targetPetId], references: [id], onDelete: Cascade)

  @@index([senderPetId])
  @@index([targetPetId])
  @@index([status, createdAt])
  @@unique([senderPetId, targetPetId, status])
  @@map("app_match_requests")
}

model AIMatch {
  id      String @id @default(uuid())
  pet1Id  String
  pet2Id  String
  score   Float
  notes   String?

  pet1 Pet @relation("AIMatchPet1", fields: [pet1Id], references: [id], onDelete: Cascade)
  pet2 Pet @relation("AIMatchPet2", fields: [pet2Id], references: [id], onDelete: Cascade)

  @@index([pet1Id])
  @@index([pet2Id])
  @@index([score])
  @@map("app_ai_matches")
}

model Conversation {
  id      String   @id @default(uuid())
  user1Id String
  user2Id String
  createdAt DateTime @default(now())

  user1 User @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id])
  @@index([createdAt])
  @@map("app_conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  text           String?
  image          String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("app_messages")
}

model HealthRecord {
  id        String @id @default(uuid())
  petId     String
  vaccine   String?
  notes     String?
  vetName   String?
  date      DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, date])
  @@map("app_health_records")
}

model SubscriptionPlan {
  id       String @id @default(uuid())
  name     String
  price    Float
  duration Int

  subscriptions UserSubscription[]

  @@unique([name])
  @@map("app_subscription_plans")
}

model UserSubscription {
  id        String @id @default(uuid())
  userId    String
  planId    String
  startDate DateTime @default(now())
  endDate   DateTime
  status    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([endDate])
  @@map("app_user_subscriptions")
}

model Payment {
  id         String @id @default(uuid())
  userId     String
  amount     Float
  method     String
  status     String
  screenshot String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@map("app_payments")
}

model GpsTrack {
  id        String   @id @default(uuid())
  userId    String?
  petId     String?
  lat       Float
  lng       Float
  accuracy  Float?
  source    String?  @default("mobile")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet  Pet?  @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([petId, createdAt])
  @@index([createdAt])
  @@map("app_gps_tracks")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventType])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("app_analytics_events")
}

model VerificationCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([expiresAt])
  @@index([code])
  @@map("app_verification_codes")
}

model DashboardMetric {
  id          String   @id @default(uuid())
  metricDate  DateTime
  totalUsers  Int      @default(0)
  totalPets   Int      @default(0)
  totalMatches Int     @default(0)
  totalPayments Float  @default(0)
  payload     Json?
  createdAt   DateTime @default(now())

  @@unique([metricDate])
  @@index([metricDate])
  @@map("app_dashboard_metrics")
}

