{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "backend": "npm --prefix server run dev",
    "frontend": "vite",
    "start": "vite",
    "start-windows": "vite",
    "dev:all": "npm run start:all",
    "start:all": "concurrently -n FRONTEND,BACKEND -c cyan,green \"npm run dev\" \"npm run backend\"",
    "db:pull": "npm --prefix server run prisma:pull",
    "db:generate": "npm --prefix server run prisma:generate",
    "test:backend": "npm --prefix server test",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:unit": "jest --config jest.config.cjs --testPathPattern=unit",
    "test:integration": "jest --config jest.integration.api.cjs",
    "test:integration:legacy": "jest --config jest.integration.cjs",
    "test:ci": "jest --config jest.config.cjs --ci --coverage --watchAll=false",
    "test:runner": "node tests/scripts/test-runner.js"
  },
